# ---------------------------------------------------------------------------
# Secrets
#
# Ignore every .env* at any depth. The only exception is .env.example — the
# committed template with empty values. This covers the common footgun of
# running `cp app/.env.example .env` from the repo root (one directory too
# high) and accidentally staging a real key.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Local Claude Code session settings (per-machine, not for publication).
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# Node / build / cache
# ---------------------------------------------------------------------------
node_modules/
dist/

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Editor state
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.#*
*~

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
