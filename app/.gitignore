# Secrets: enforced at repo root too, duplicated here so devs working in /app
# see the rule without climbing the tree. .env.example is the only exception.
.env
.env.*
!.env.example

node_modules/
dist/

# Rendered audio under public/assets/audio/ IS committed — it's the canonical
# archival artifact served by GitHub Pages and by any offline player.
# Temporary direction JSON written by render:scene/render:all to dist/ is not.
